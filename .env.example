# MGP AI Travel Bot — Environment Variables
# cp .env.example .env && nano .env
# ВАЖНО: Все значения REPLACE_ME нужно заменить перед запуском!

# === LLM Provider ===
LLM_PROVIDER=openai                    # yandex | openai

# === Yandex GPT ===
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt

# === OpenAI ===
OPENAI_API_KEY=REPLACE_ME
OPENAI_BASE_URL=                       # proxy URL if needed (e.g. https://openrouter.ai/api/v1)
OPENAI_MODEL=gpt-5-mini

# === TourVisor API ===
TOURVISOR_AUTH_LOGIN=REPLACE_ME
TOURVISOR_AUTH_PASS=REPLACE_ME
TOURVISOR_BASE_URL=https://tourvisor.ru/xml

# === PostgreSQL ===
# Сгенерировать: openssl rand -hex 16
POSTGRES_DB=mgp
POSTGRES_USER=mgp
POSTGRES_PASSWORD=REPLACE_ME

# === Redis ===
REDIS_PASSWORD=changeme_redis
# REDIS_URL конструируется автоматически в docker-compose.yml из REDIS_PASSWORD

# === Security ===
# ALLOWED_ORIGINS — разрешённые домены для CORS (через запятую)
# Пример: https://yourdomain.ru,http://localhost:8080
ALLOWED_ORIGINS=
CORS_ORIGINS=REPLACE_ME

# === Runtime mode ===
# production target фиксирован как backend-only: widget UI живёт в LK,
# а MGP обслуживает runtime API и встроенный admin dashboard
RUNTIME_MODE=backend-only
LK_WIDGET_LOADER_URL=https://lk.navilet.ru/widget-loader.js
APP_PORT=80
RUNTIME_INSTANCE_ID=mgp-runtime-template
RUNTIME_PUBLIC_BASE_URL=

# === Runtime security / LK service auth ===
# off      — полностью выключено
# monitor  — логируем/разбираем service auth, но не режем совместимость
# enforce  — пускаем только trusted callers / валидный service auth
# phase-1 exact contract: X-MGP-Service-Token = plain shared secret
RUNTIME_SERVICE_AUTH_MODE=monitor
RUNTIME_SERVICE_AUTH_SECRET=
RUNTIME_SERVICE_AUTH_MAX_SKEW_SECONDS=300
RUNTIME_TRUSTED_SERVICE_IDS=lk
RUNTIME_TRUSTED_PROXY_CIDRS=
RUNTIME_ALLOW_TRUSTED_PROXY_BYPASS=true

# === Control-plane reporting (optional) ===
RUNTIME_REPORT_URL=
RUNTIME_REPORT_TOKEN=
RUNTIME_DIALOG_SENDER_ENABLED=true
RUNTIME_DIALOG_SENDER_BATCH_SIZE=20
RUNTIME_DIALOG_SENDER_INTERVAL_SECONDS=10
RUNTIME_DIALOG_SENDER_TIMEOUT_SECONDS=15
RUNTIME_DIALOG_SENDER_MAX_ATTEMPTS=5
RUNTIME_DIALOG_SENDER_RETRY_BACKOFF_SECONDS=10
RUNTIME_DIALOG_SENDER_RETRY_BACKOFF_MAX_SECONDS=300
RUNTIME_PROVISIONING_API_TOKEN=
RUNTIME_PROVISIONING_CALLBACK_TIMEOUT_SECONDS=15
RUNTIME_PROVISIONING_CALLBACK_MAX_ATTEMPTS=3
RUNTIME_PROVISIONING_CALLBACK_BACKOFF_SECONDS=2

# === Server ===
LOG_LEVEL=INFO
LOG_FORMAT=text                        # text | json
SESSION_TTL_SECONDS=1800

# === Dashboard Auth ===
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=REPLACE_ME

# === Auto-Seed (первый запуск) ===
SEED_ADMIN_EMAIL=REPLACE_ME
SEED_ADMIN_PASSWORD=REPLACE_ME
SEED_COMPANY_NAME=REPLACE_ME
SEED_COMPANY_SLUG=REPLACE_ME
SEED_COMPANY_LOGO_URL=
SEED_ASSISTANT_NAME=
SEED_ASSISTANT_ALLOWED_DOMAINS=
SEED_ASSISTANT_BOT_SERVER_URL=
SEED_SYSTEM_PROMPT_FILE=
SEED_FAQ_FILE=
SEED_WIDGET_TITLE=
SEED_WIDGET_SUBTITLE=
SEED_WIDGET_PRIMARY_COLOR=
SEED_WIDGET_POSITION=
SEED_WIDGET_LOGO_URL=

# === MGP Bot Sync (remote DB connection) ===
SYNC_MGP_ENABLED=true
SYNC_MGP_INTERVAL_MINUTES=5
MGP_SSH_HOST=REPLACE_ME
MGP_SSH_PORT=22
MGP_SSH_USER=root
MGP_SSH_PASSWORD=REPLACE_ME             # fallback if SSH key not available
MGP_SSH_KEY_PATH=/opt/lk-aimpact/sync_key
MGP_PG_USER=mgp
MGP_PG_PASSWORD=REPLACE_ME
MGP_PG_DB=mgp
MGP_PG_PORT=5432

# === AI Report ===
AI_REPORT_API_KEY=REPLACE_ME
AI_REPORT_MODEL=openai/gpt-4.1-mini

# === Widget ===
WIDGET_HOST_URL=https://lk.navilet.ru   # URL для embed-кода виджета

# === Resource Tuning ===
PG_SHARED_BUFFERS=64MB                # 64MB для 2GB RAM, 128MB для 4GB+
PG_EFFECTIVE_CACHE=256MB              # 256MB для 2GB RAM, 512MB для 4GB+
PG_MAX_CONN=20                        # 20 для 2GB RAM, 50 для 4GB+
REDIS_MAXMEMORY=64mb                  # 64mb для 2GB RAM, 128mb для 4GB+
GUNICORN_WORKERS=2                    # 2 для 2GB RAM, 4 для 4GB+
GUNICORN_THREADS=4                    # 4 для 2GB RAM, 4 для 4GB+
