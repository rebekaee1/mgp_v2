# MGP AI Travel Bot — Environment Variables
# cp .env.example .env && nano .env

# === LLM Provider ===
LLM_PROVIDER=openai                    # yandex | openai

# === Yandex GPT ===
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt

# === OpenAI ===
OPENAI_API_KEY=
OPENAI_BASE_URL=                       # proxy URL if needed (e.g. https://openrouter.ai/api/v1)
OPENAI_MODEL=gpt-5-mini

# === TourVisor API ===
TOURVISOR_AUTH_LOGIN=
TOURVISOR_AUTH_PASS=
TOURVISOR_BASE_URL=https://tourvisor.ru/xml

# === PostgreSQL ===
# POSTGRES_PASSWORD — ОБЯЗАТЕЛЬНО сменить! (openssl rand -hex 16)
POSTGRES_DB=mgp
POSTGRES_USER=mgp
POSTGRES_PASSWORD=changeme
# DATABASE_URL конструируется автоматически в docker-compose.yml из POSTGRES_* переменных

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Server ===
LOG_LEVEL=INFO
LOG_FORMAT=text                        # text | json
SESSION_TTL_SECONDS=1800

# === Dashboard Auth ===
# JWT_SECRET — ОБЯЗАТЕЛЬНО сменить! (openssl rand -hex 32)
# Если не задан — auto-генерируется при старте (не сохраняется между перезапусками)
JWT_SECRET=change-me-in-production-please

# === Auto-Seed (первый запуск) ===
SEED_ADMIN_EMAIL=admin@company.com
SEED_ADMIN_PASSWORD=                   # если пусто — auto-генерируется, выводится в лог
SEED_COMPANY_NAME=My Company
SEED_COMPANY_SLUG=my-company

# === MGP Bot Sync (remote DB connection) ===
# ЛК подтягивает диалоги из удалённого MGP-бота каждые N минут
SYNC_MGP_ENABLED=true
SYNC_MGP_INTERVAL_MINUTES=5
MGP_SSH_HOST=                          # IP сервера с MGP ботом
MGP_SSH_PORT=22
MGP_SSH_USER=root
MGP_SSH_PASSWORD=                      # пароль SSH
MGP_PG_USER=mgp
MGP_PG_PASSWORD=                       # пароль PostgreSQL на сервере MGP
MGP_PG_DB=mgp
MGP_PG_PORT=5432

# === Resource Tuning ===
PG_SHARED_BUFFERS=64MB                # 64MB для 2GB RAM, 128MB для 4GB+
PG_EFFECTIVE_CACHE=256MB              # 256MB для 2GB RAM, 512MB для 4GB+
PG_MAX_CONN=20                        # 20 для 2GB RAM, 50 для 4GB+
REDIS_MAXMEMORY=64mb                  # 64mb для 2GB RAM, 128mb для 4GB+
GUNICORN_WORKERS=2                    # 2 для 2GB RAM, 4 для 4GB+
GUNICORN_THREADS=4                    # 4 для 2GB RAM, 4 для 4GB+
APP_PORT=80                           # порт фронтенда (80 по умолчанию)
